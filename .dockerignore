# 버전 관리
.git
.github
**/.gitignore

# Python 캐시
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# 가상환경
**/.venv
**/venv
**/env

# 모델 가중치 — 이미지에 포함하지 않고 볼륨 마운트로 주입
apps/trainer/src/models/**/*.pth
apps/trainer/src/models/**/*.pt
apps/trainer/src/models/**/*.ckpt
apps/trainer/src/models/**/*.h5

# 학습 코드 — 운영 이미지에 불필요
apps/trainer/
apps/sagemaker_inference/
apps/sagemaker_rf_inference/

# 로컬 출력 및 임시 파일
apps/ai_api/data/output/

# 환경 파일 (서버에서 직접 주입)
.env
apps/ai_api/.env

# 문서
docs/
*.md

# 빌드 관련
buildspec*.yml
docker-compose.yml
