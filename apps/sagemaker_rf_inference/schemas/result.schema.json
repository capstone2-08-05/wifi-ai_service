{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capstone2/contracts/rf-inference/result.schema.json",
  "title": "RF Inference Result (Success)",
  "description": "정상 종료 시 output_prefix/result.json 에 기록되는 페이로드.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "job_id",
    "completed_at",
    "outputs",
    "stages",
    "radio_map"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "status": { "type": "string", "const": "completed" },
    "job_id": { "type": "string" },
    "project_id": { "type": ["string", "null"] },
    "floor_id": { "type": ["string", "null"] },
    "scene_version_id": { "type": ["string", "null"] },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result_s3_uri", "heatmap_s3_uri", "radio_map_s3_uri"],
      "properties": {
        "result_s3_uri": { "type": "string", "pattern": "^s3://" },
        "heatmap_s3_uri": { "type": "string", "pattern": "^s3://", "description": "사용자 노출용 시각화 PNG (dBm → 컬러 매핑)." },
        "radio_map_s3_uri": { "type": "string", "pattern": "^s3://", "description": "raw 2D numpy array (.npy), shape (rows, cols), values = dBm." }
      }
    },
    "stages": {
      "type": "object",
      "additionalProperties": false,
      "description": "컨테이너 측 각 단계별 실행 시간(ms).",
      "properties": {
        "download_scene_ms": { "type": "integer", "minimum": 0 },
        "parse_scene_ms": { "type": "integer", "minimum": 0 },
        "ray_tracing_ms": { "type": "integer", "minimum": 0 },
        "upload_ms": { "type": "integer", "minimum": 0 },
        "total_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "radio_map": {
      "type": "object",
      "additionalProperties": false,
      "required": ["grid_shape", "bounds_m", "cell_size_m"],
      "description": "radio map 메타데이터. raw 데이터 자체는 radio_map.npy 에.",
      "properties": {
        "grid_shape": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 },
          "minItems": 2,
          "maxItems": 2,
          "description": "[rows, cols]"
        },
        "bounds_m": {
          "type": "object",
          "additionalProperties": false,
          "required": ["min_x", "max_x", "min_y", "max_y", "z"],
          "properties": {
            "min_x": { "type": "number" },
            "max_x": { "type": "number" },
            "min_y": { "type": "number" },
            "max_y": { "type": "number" },
            "z": { "type": "number", "description": "측정 평면 높이 (미터)." }
          }
        },
        "cell_size_m": { "type": "number", "exclusiveMinimum": 0 },
        "valid_cell_count": { "type": "integer", "minimum": 0 },
        "invalid_cell_count": { "type": "integer", "minimum": 0 },
        "valid_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "rss_dbm": {
          "type": "object",
          "description": "유효 셀의 dBm 통계.",
          "properties": {
            "min": { "type": ["number", "null"] },
            "max": { "type": ["number", "null"] },
            "mean": { "type": ["number", "null"] }
          }
        },
        "coverage_summary": {
          "type": "object",
          "description": "주요 임계값별 커버리지 비율 (전체 셀 기준).",
          "additionalProperties": true
        }
      }
    },
    "access_points": {
      "type": "array",
      "description": "input access_points 를 echo back. 디버깅용.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "container_version": { "type": "string" },
        "device": { "type": "string", "description": "예: cuda:0, cpu" },
        "engine": { "type": "string", "description": "예: sionna_rt" },
        "sionna_version": { "type": "string" }
      }
    },
    "echo": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
