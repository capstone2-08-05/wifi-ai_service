HOST=0.0.0.0
PORT=9000

# Model paths
UNET_CHECKPOINT_PATH=apps/trainer/src/models/unet/best_unet.pth
UNET_CONFIG_PATH=apps/ai_api/configs/unet_inference.yaml
YOLO_MODEL_PATH=apps/trainer/src/models/yolo/best.pt
YOLO_CONFIG_PATH=apps/ai_api/configs/yolo_inference.yaml

# Inference runtime
YOLO_CONF_THRESHOLD=0.25
YOLO_DEVICE=
DEFAULT_DEVICE=auto
PRELOAD_MODELS=false

# RF artifact URL (single template, change this later for S3/CDN)
RF_ARTIFACT_IMAGE_URL_TEMPLATE=http://localhost:9000/internal/rf/images/{rf_run_id}.png

# Sionna RT runtime options
SIONNA_CELL_SIZE_M=0.25
SIONNA_SAMPLES_PER_TX=100000
SIONNA_SEED=42