HOST=0.0.0.0
PORT=9000

# Model paths
UNET_CHECKPOINT_PATH=apps/trainer/src/models/unet/best_unet.pth
UNET_CONFIG_PATH=apps/ai_api/configs/unet_inference.yaml
YOLO_MODEL_PATH=apps/trainer/src/models/yolo/best.pt
YOLO_CONFIG_PATH=apps/ai_api/configs/yolo_inference.yaml
# Inference runtime
YOLO_CONF_THRESHOLD=0.25
YOLO_DEVICE=
DEFAULT_DEVICE=auto
PRELOAD_MODELS=false

# Sionna artifact URL (single template, change this later for S3/CDN)
SIONNA_ARTIFACT_IMAGE_URL_TEMPLATE=http://localhost:9000/internal/sionna/images/{sionna_run_id}.png

# Sionna RT defaults (frequency/power/depth/samples/seed/propagation) are managed in
# app.domain.entities.radio.SimulationConfig — request payload overrides per-call.