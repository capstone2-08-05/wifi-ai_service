HOST=0.0.0.0
PORT=8080

# 모델 경로 — 컨테이너 내부 절대 경로 (볼륨 마운트 위치와 일치시킬 것)
# docker run: -v /opt/rf-service/models:/opt/models:ro
UNET_CHECKPOINT_PATH=/opt/models/unet/best_unet.pth
UNET_CONFIG_PATH=/opt/app/apps/ai_api/configs/unet_inference.yaml

YOLO_MODEL_PATH=/opt/models/yolo/best.pt
YOLO_CONFIG_PATH=/opt/app/apps/ai_api/configs/yolo_inference.yaml

# 추론 런타임
YOLO_CONF_THRESHOLD=0.25
YOLO_DEVICE=
DEFAULT_DEVICE=auto
PRELOAD_MODELS=true

# Sionna artifact URL — 프론트엔드나 백엔드에서 접근 가능한 URL로 변경
SIONNA_ARTIFACT_IMAGE_URL_TEMPLATE=http://<서버_IP>:8080/internal/sionna/images/{sionna_run_id}.png

# CORS — 프론트엔드 도메인 추가 (콤마 구분)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://3.34.1.198:8000
